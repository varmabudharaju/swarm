{
  "hooks": {
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}\" python3 -m swarm_lib.hook"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}\" python3 -m swarm_lib.cli install-workflow"
          },
          {
            "type": "command",
            "command": "PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}\" python3 -m swarm_lib.hook"
          }
        ]
      }
    ]
  }
}
